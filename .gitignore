# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VS Code settings
.vscode/

# python-dotenv files
.env

# temp files
*.log
*.tmp
*.bak
*.swp

# pytest cache
.pytest_cache/

# model files
*.pkl
*.joblib

# Ignore all files except .gitkeep in data, models, and reports
data/*
!data/.gitkeep
models/*
!models/.gitkeep
reports/*
!reports/.gitkeep